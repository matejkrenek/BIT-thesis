# Copy this file to .env and adjust values for your machine.

# Project root used as fallback for data/checkpoint/output directories.
ROOT_DIR="/absolute/path/to/project"

# Output directory for generated files (plots, exports, reports).
OUTPUT_DIR="/absolute/path/to/project/outputs"

# Optional overrides (uncomment if needed):
# DATA_DIR="/absolute/path/to/project/data"
# CHECKPOINT_DIR="/absolute/path/to/project/checkpoints"

# Optional integrations:
# HF_TOKEN=""
# DISCORD_WEBHOOK_URL=""
